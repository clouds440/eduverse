// ─── CHAT SYSTEM ────────────────────────────────────────────────────────────

enum ChatType {
  DIRECT
  GROUP
}

enum ChatParticipantRole {
  ADMIN
  MOD
  MEMBER
}

enum ChatMessageType {
  TEXT
  SYSTEM
}

enum CommunicationChannel {
  DIRECT_MESSAGE
}

enum E2EEContentType {
  CHAT_MESSAGE
  MAIL_MESSAGE
  MAIL_SUBJECT
  FILE_ATTACHMENT
}

enum E2EEDeviceTrustStatus {
  PENDING
  TRUSTED
  REVOKED
}

enum E2EEApprovalStatus {
  PENDING
  APPROVED
  DENIED
  EXPIRED
  CANCELLED
}

enum E2EEHistoryKeyScope {
  CHAT_USER
}

model Chat {
  id             String   @id @default(uuid())
  type           ChatType
  name           String? // For group chats
  avatarUrl      String? // Group picture URL
  avatarUpdatedAt DateTime?
  organizationId String? // Null if platform-level chat
  creatorId      String // User who created the group
  readOnly       Boolean  @default(false) // If true, only ADMIN and MOD can send messages

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization?     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  creator      User              @relation("CreatedChats", fields: [creatorId], references: [id])
  participants ChatParticipant[]
  messages     ChatMessage[]
  communicationBlocks UserCommunicationBlock[] @relation("CommunicationBlockChat")
  historyKeys  ChatHistoryKey[] @relation("ChatHistoryKeys")

  @@index([organizationId])
}

model ChatParticipant {
  id                String                  @id @default(uuid())
  chatId            String
  userId            String
  role              ChatParticipantRole     @default(MEMBER)
  isActive          Boolean                  @default(true)
  lastReadMessageId String?
  lastSeenAt        DateTime?
  joinedAt          DateTime                 @default(now())
  
  // User-local chat state
  hiddenAt          DateTime?
  clearedAt         DateTime?
  membershipHistory ChatMembershipHistory[]

  chat Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  user User @relation("ChatParticipations", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([chatId, userId])
  @@index([userId])
}

model ChatMembershipHistory {
  id                String   @id @default(uuid())
  chatParticipantId String
  activatedAt       DateTime @default(now())
  deactivatedAt     DateTime?

  participant ChatParticipant @relation(fields: [chatParticipantId], references: [id], onDelete: Cascade)

  @@index([chatParticipantId])
}


model ChatMessage {
  id             String          @id @default(uuid())
  chatId         String
  senderId       String
  organizationId String?
  content        String // markdown supported
  type           ChatMessageType @default(TEXT)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  deletedAt      DateTime?
  deletedById    String?

  chat        Chat  @relation(fields: [chatId], references: [id], onDelete: Cascade)
  sender      User  @relation("SentChatMessages", fields: [senderId], references: [id])
  deletedBy   User? @relation("DeletedChatMessages", fields: [deletedById], references: [id])

  replyToId String?
  replyTo   ChatMessage?  @relation("ChatReply", fields: [replyToId], references: [id])
  replies   ChatMessage[] @relation("ChatReply")
  encryptedContent EncryptedContent? @relation("ChatMessageEncryptedContent")

  @@index([chatId, createdAt])
  @@index([senderId])
}

model EncryptedContent {
  id                String          @id @default(uuid())
  contentType       E2EEContentType
  chatMessageId     String?         @unique
  mailMessageId     String?         @unique
  mailId            String?         @unique
  fileId            String?         @unique
  encryptionVersion Int
  algorithm         String
  ciphertext        String
  nonce             String
  authTag           String?
  associatedData    Json?
  contentKeyVersion Int             @default(1)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  chatMessage  ChatMessage?        @relation("ChatMessageEncryptedContent", fields: [chatMessageId], references: [id], onDelete: Cascade)
  mailMessage  MailMessage?        @relation("MailMessageEncryptedContent", fields: [mailMessageId], references: [id], onDelete: Cascade)
  mailSubject  Mail?               @relation("MailSubjectEncryptedContent", fields: [mailId], references: [id], onDelete: Cascade)
  file         File?               @relation("FileEncryptedContent", fields: [fileId], references: [id], onDelete: Cascade)
  keyEnvelopes E2EEKeyEnvelope[]
  historyKeyEnvelopes E2EEContentHistoryKeyEnvelope[]

  @@index([contentType])
  @@index([chatMessageId])
  @@index([mailMessageId])
  @@index([mailId])
  @@index([fileId])
  @@index([encryptionVersion])
  @@index([createdAt])
}

model E2EEKeyEnvelope {
  id                 String   @id @default(uuid())
  encryptedContentId String
  recipientUserId    String
  trustedDeviceId    String
  senderDeviceId     String?
  deviceKeyVersion   Int
  algorithm          String
  wrappedKey         String
  nonce              String?
  associatedData     Json?
  createdAt          DateTime @default(now())

  encryptedContent EncryptedContent         @relation(fields: [encryptedContentId], references: [id], onDelete: Cascade)
  recipientUser    User                     @relation("E2EEKeyEnvelopeRecipients", fields: [recipientUserId], references: [id], onDelete: Cascade)
  trustedDevice    TrustedEncryptionDevice  @relation("E2EEKeyEnvelopeTargetDevices", fields: [trustedDeviceId], references: [id], onDelete: Cascade)
  senderDevice     TrustedEncryptionDevice? @relation("E2EEKeyEnvelopeSenderDevices", fields: [senderDeviceId], references: [id], onDelete: SetNull)

  @@unique([encryptedContentId, trustedDeviceId])
  @@index([recipientUserId])
  @@index([trustedDeviceId])
  @@index([senderDeviceId])
  @@index([createdAt])
}

// ─── NOTIFICATION SYSTEM ─────────────────────────────────────────────────────
model ChatHistoryKey {
  id          String              @id @default(uuid())
  chatId      String
  userId      String
  scope       E2EEHistoryKeyScope @default(CHAT_USER)
  epoch       Int                 @default(1)
  keyVersion  Int                 @default(1)
  algorithm   String              @default("libsodium:xchacha20poly1305-ietf")
  createdAt   DateTime            @default(now())
  rotatedAt   DateTime?
  revokedAt   DateTime?

  chat             Chat                            @relation("ChatHistoryKeys", fields: [chatId], references: [id], onDelete: Cascade)
  user             User                            @relation("ChatHistoryKeyUsers", fields: [userId], references: [id], onDelete: Cascade)
  deviceEnvelopes  E2EEHistoryKeyDeviceEnvelope[]
  contentEnvelopes E2EEContentHistoryKeyEnvelope[]

  @@unique([chatId, userId, epoch])
  @@index([chatId, epoch])
  @@index([userId])
  @@index([scope])
  @@index([revokedAt])
}

model E2EEHistoryKeyDeviceEnvelope {
  id               String   @id @default(uuid())
  historyKeyId     String
  recipientUserId  String
  trustedDeviceId  String
  senderDeviceId   String?
  deviceKeyVersion Int
  algorithm        String
  wrappedKey       String
  nonce            String?
  associatedData   Json?
  createdAt        DateTime @default(now())

  historyKey    ChatHistoryKey           @relation(fields: [historyKeyId], references: [id], onDelete: Cascade)
  recipientUser User                     @relation("E2EEHistoryKeyEnvelopeRecipients", fields: [recipientUserId], references: [id], onDelete: Cascade)
  trustedDevice TrustedEncryptionDevice  @relation("E2EEHistoryKeyEnvelopeTargetDevices", fields: [trustedDeviceId], references: [id], onDelete: Cascade)
  senderDevice  TrustedEncryptionDevice? @relation("E2EEHistoryKeyEnvelopeSenderDevices", fields: [senderDeviceId], references: [id], onDelete: SetNull)

  @@unique([historyKeyId, trustedDeviceId])
  @@index([recipientUserId])
  @@index([trustedDeviceId])
  @@index([senderDeviceId])
  @@index([createdAt])
}

model E2EEContentHistoryKeyEnvelope {
  id                 String   @id @default(uuid())
  encryptedContentId String
  historyKeyId       String
  recipientUserId    String
  algorithm          String
  wrappedKey         String
  nonce              String?
  associatedData     Json?
  createdAt          DateTime @default(now())

  encryptedContent EncryptedContent @relation(fields: [encryptedContentId], references: [id], onDelete: Cascade)
  historyKey       ChatHistoryKey   @relation(fields: [historyKeyId], references: [id], onDelete: Cascade)
  recipientUser    User             @relation("E2EEContentHistoryKeyEnvelopeRecipients", fields: [recipientUserId], references: [id], onDelete: Cascade)

  @@unique([encryptedContentId, historyKeyId])
  @@index([historyKeyId])
  @@index([recipientUserId])
  @@index([createdAt])
}

model UserCommunicationBlock {
  id             String               @id @default(uuid())
  userId         String
  targetUserId   String
  chatId         String?
  organizationId String?
  channel        CommunicationChannel @default(DIRECT_MESSAGE)
  createdAt      DateTime             @default(now())

  user         User          @relation("CommunicationBlockOwners", fields: [userId], references: [id], onDelete: Cascade)
  targetUser   User          @relation("CommunicationBlockTargets", fields: [targetUserId], references: [id], onDelete: Cascade)
  chat         Chat?         @relation("CommunicationBlockChat", fields: [chatId], references: [id], onDelete: SetNull)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, targetUserId, channel])
  @@index([userId])
  @@index([targetUserId])
  @@index([chatId, channel])
  @@index([organizationId])
  @@index([channel])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  body      String?
  actionUrl String?
  type      String?
  metadata  Json?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([createdAt])
}

// ─── ANNOUNCEMENT SYSTEM ─────────────────────────────────────────────────────
enum AnnouncementPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum TargetType {
  GLOBAL
  ORG
  ROLE
  SECTION
  COURSE
  COHORT
}

enum AISubscriptionPlan {
  NONE
  STARTER
  GROWTH
  SCALE
}

enum AISubscriptionOwnerType {
  ORGANIZATION
  USER
}

enum AISubscriptionStatus {
  INACTIVE
  ACTIVE
  CANCELED
  PAST_DUE
}

enum AILimitMode {
  HARD
  SOFT
}

enum AIUsageSourceType {
  ORGANIZATION
  PERSONAL
}

enum AIMessageRole {
  USER
  ASSISTANT
  SYSTEM
  TOOL
}

model AISubscription {
  id                 String                  @id @default(uuid())
  ownerType          AISubscriptionOwnerType
  organizationId     String?
  userId             String?
  plan               AISubscriptionPlan      @default(NONE)
  status             AISubscriptionStatus    @default(INACTIVE)
  monthlyCredits     Int                     @default(0)
  limitMode          AILimitMode             @default(HARD)
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  lemonSqueezyCustomerId     String?
  lemonSqueezySubscriptionId String?
  lemonSqueezyVariantId      String?
  lemonSqueezyPortalUrl      String?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  usages       AIUsage[]
  toolCallLogs AIToolCallLog[]
  conversations AIConversation[]

  @@unique([ownerType, organizationId])
  @@unique([ownerType, userId])
  @@index([ownerType])
  @@index([plan])
  @@index([status])
  @@index([lemonSqueezyCustomerId])
  @@index([lemonSqueezySubscriptionId])
  @@index([organizationId])
  @@index([userId])
  @@index([currentPeriodEnd])
}

model AIOrgAccessPolicy {
  id                   String   @id @default(uuid())
  organizationId       String   @unique
  allowSubAdmins       Boolean  @default(false)
  allowManagers        Boolean  @default(false)
  allowFinanceManagers Boolean  @default(false)
  allowTeachers        Boolean  @default(false)
  allowStudents        Boolean  @default(false)
  allowGuardians       Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model AIRoleCreditPolicy {
  id             String   @id @default(uuid())
  organizationId String
  role           Role
  monthlyCredits Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, role])
  @@index([organizationId])
  @@index([role])
}

model AIUsage {
  id                    String            @id @default(uuid())
  subscriptionId        String
  sourceType            AIUsageSourceType
  organizationId        String?
  userId                String
  role                  Role?
  periodStart           DateTime
  periodEnd             DateTime
  creditUsed            Int               @default(0)
  providerTokenEstimate Int               @default(0)
  estimatedCost         Decimal           @default(0.00) @db.Decimal(12, 4)
  overageCredits        Int               @default(0)
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  subscription AISubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  organization Organization?  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([subscriptionId, userId, periodStart])
  @@index([subscriptionId])
  @@index([sourceType])
  @@index([organizationId])
  @@index([userId])
  @@index([role])
  @@index([periodStart])
  @@index([periodEnd])
}

model AIToolCallLog {
  id                    String             @id @default(uuid())
  userId                String?
  orgId                 String?
  subscriptionId        String?
  sourceType            AIUsageSourceType?
  toolName              String
  allowed               Boolean
  latencyMs             Int
  creditEstimate        Int?
  providerTokenEstimate Int?
  createdAt             DateTime           @default(now())

  user         User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  organization Organization?   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  subscription AISubscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([orgId])
  @@index([subscriptionId])
  @@index([sourceType])
  @@index([toolName])
  @@index([allowed])
  @@index([createdAt])
}

model AIConversation {
  id             String    @id @default(uuid())
  userId         String
  organizationId String?
  subscriptionId String?
  title          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  expiresAt      DateTime?

  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization?   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  subscription AISubscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  messages     AIMessage[]

  @@index([userId])
  @@index([organizationId])
  @@index([subscriptionId])
  @@index([expiresAt])
  @@index([updatedAt])
}

model AIMessage {
  id             String        @id @default(uuid())
  conversationId String
  role           AIMessageRole
  content        String
  metadata       Json?
  createdAt      DateTime      @default(now())

  conversation AIConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([role])
  @@index([createdAt])
}

enum HolidayType {
  HOLIDAY
  EXAM_BREAK
  EVENT
  CLOSURE
}

enum HolidayMatchMode {
  SINGLE_DAY
  DATE_RANGE
  WEEKDAYS_IN_RANGE
  DAILY_IN_RANGE
}

model Announcement {
  id             String     @id @default(uuid())
  title          String
  body           String // Markdown
  targetType     TargetType
  targetId       String? // e.g. orgId, role name, or sectionId
  actionUrl      String?
  priority       AnnouncementPriority @default(NORMAL)
  creatorId      String
  organizationId String? // Scope to org if applicable
  createdAt      DateTime   @default(now())

  creator      User          @relation("CreatedAnnouncements", fields: [creatorId], references: [id])
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  preferenceWindows PreferenceWindow[]

  @@index([organizationId])
  @@index([targetType, targetId])
}

enum PreferenceWindowKind {
  SECTION_CHOICE
  COURSE_CHOICE
}

enum PreferenceWindowStatus {
  DRAFT
  ACTIVE
  CLOSED
  ARCHIVED
}

enum PreferenceTargetType {
  COURSE
  COHORT
  SECTION
}

model PreferenceWindow {
  id              String                 @id @default(uuid())
  organizationId  String
  academicCycleId String
  title           String
  description     String?
  kind            PreferenceWindowKind
  status          PreferenceWindowStatus @default(DRAFT)
  startAt         DateTime
  endAt           DateTime
  announcementId  String?
  createdById     String
  updatedById     String?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  organization  Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  academicCycle AcademicCycle @relation(fields: [academicCycleId], references: [id], onDelete: Cascade)
  announcement  Announcement? @relation(fields: [announcementId], references: [id], onDelete: SetNull)
  createdBy     User          @relation("CreatedPreferenceWindows", fields: [createdById], references: [id])
  updatedBy     User?         @relation("UpdatedPreferenceWindows", fields: [updatedById], references: [id])
  options       PreferenceWindowOption[]
  audiences     PreferenceWindowAudience[]
  submissions   PreferenceSubmission[]

  @@index([organizationId])
  @@index([academicCycleId])
  @@index([kind])
  @@index([status])
  @@index([startAt, endAt])
  @@index([announcementId])
}

model PreferenceWindowOption {
  id           String               @id @default(uuid())
  windowId     String
  targetType   PreferenceTargetType
  courseId     String?
  sectionId    String?
  displayOrder Int                  @default(0)

  window  PreferenceWindow @relation(fields: [windowId], references: [id], onDelete: Cascade)
  course  Course?          @relation("PreferenceOptionCourse", fields: [courseId], references: [id], onDelete: Cascade)
  section Section?         @relation("PreferenceOptionSection", fields: [sectionId], references: [id], onDelete: Cascade)
  ranks   PreferenceRank[]

  @@index([windowId])
  @@index([courseId])
  @@index([sectionId])
  @@unique([windowId, courseId])
  @@unique([windowId, sectionId])
}

model PreferenceWindowAudience {
  id         String               @id @default(uuid())
  windowId   String
  targetType PreferenceTargetType
  courseId   String?
  cohortId   String?
  sectionId  String?

  window  PreferenceWindow @relation(fields: [windowId], references: [id], onDelete: Cascade)
  course  Course?          @relation("PreferenceAudienceCourse", fields: [courseId], references: [id], onDelete: Cascade)
  cohort  Cohort?          @relation(fields: [cohortId], references: [id], onDelete: Cascade)
  section Section?         @relation("PreferenceAudienceSection", fields: [sectionId], references: [id], onDelete: Cascade)

  @@index([windowId])
  @@index([courseId])
  @@index([cohortId])
  @@index([sectionId])
  @@unique([windowId, courseId])
  @@unique([windowId, cohortId])
  @@unique([windowId, sectionId])
}

model PreferenceSubmission {
  id            String   @id @default(uuid())
  windowId      String
  studentId     String
  submittedById String
  submittedAt   DateTime @default(now())
  updatedAt     DateTime @updatedAt

  window      PreferenceWindow @relation(fields: [windowId], references: [id], onDelete: Cascade)
  student     Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  submittedBy User             @relation("PreferenceSubmissionUsers", fields: [submittedById], references: [id])
  ranks       PreferenceRank[]

  @@unique([windowId, studentId])
  @@index([windowId])
  @@index([studentId])
  @@index([submittedById])
}

model PreferenceRank {
  id           String @id @default(uuid())
  submissionId String
  optionId     String
  rank         Int

  submission PreferenceSubmission  @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  option     PreferenceWindowOption @relation(fields: [optionId], references: [id], onDelete: Cascade)

  @@unique([submissionId, optionId])
  @@unique([submissionId, rank])
  @@index([optionId])
}

// ─── TIMETABLE & ATTENDANCE SYSTEM ──────────────────────────────────────────

model Holiday {
  id             String           @id @default(uuid())
  organizationId String
  title          String
  description    String?
  type           HolidayType      @default(HOLIDAY)
  matchMode      HolidayMatchMode @default(SINGLE_DAY)
  departmentScopeType DepartmentScopeType @default(ALL)
  startDate      DateTime
  endDate        DateTime
  startTime      String?
  endTime        String?
  daysOfWeek     Int[]            @default([])
  isFullDay      Boolean          @default(true)
  isActive       Boolean          @default(true)
  createdById    String
  updatedById    String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User         @relation("CreatedHolidays", fields: [createdById], references: [id])
  updatedBy    User?        @relation("UpdatedHolidays", fields: [updatedById], references: [id])
  departmentLinks HolidayDepartment[]

  @@index([organizationId])
  @@index([organizationId, isActive])
  @@index([organizationId, startDate, endDate])
  @@index([type])
  @@index([matchMode])
}

model HolidayDepartment {
  holidayId    String
  departmentId String
  assignedAt   DateTime @default(now())

  holiday    Holiday    @relation(fields: [holidayId], references: [id], onDelete: Cascade)
  department Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@id([holidayId, departmentId])
  @@index([departmentId])
}

model EvaluationWindow {
  id              String   @id @default(uuid())
  organizationId  String
  academicCycleId String
  courseId        String?
  sectionId       String?
  title           String
  description     String?
  startDate       DateTime
  endDate         DateTime
  isActive        Boolean  @default(true)
  createdById     String
  updatedById     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization  Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  academicCycle AcademicCycle @relation(fields: [academicCycleId], references: [id], onDelete: Cascade)
  course        Course?       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  section       Section?      @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  createdBy     User         @relation("CreatedEvaluationWindows", fields: [createdById], references: [id])
  updatedBy     User?        @relation("UpdatedEvaluationWindows", fields: [updatedById], references: [id])
  evaluations   Evaluation[]

  @@index([organizationId])
  @@index([organizationId, isActive])
  @@index([academicCycleId])
  @@index([courseId])
  @@index([sectionId])
  @@index([startDate, endDate])
}

model Evaluation {
  id              String         @id @default(uuid())
  organizationId  String
  type            EvaluationType
  studentId       String
  sectionId       String
  courseId        String
  teacherId       String?
  academicCycleId String
  windowId        String?
  rating          Int
  feedback        String?
  isHidden        Boolean        @default(false)
  hiddenById      String?
  hiddenAt        DateTime?
  hiddenReason    String?
  createdById     String
  updatedById     String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  organization  Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  student       Student           @relation(fields: [studentId], references: [id], onDelete: Cascade)
  section       Section           @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  course        Course            @relation(fields: [courseId], references: [id], onDelete: Cascade)
  teacher       Teacher?          @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  academicCycle AcademicCycle     @relation(fields: [academicCycleId], references: [id], onDelete: Cascade)
  window        EvaluationWindow? @relation(fields: [windowId], references: [id], onDelete: SetNull)
  createdBy     User              @relation("CreatedEvaluations", fields: [createdById], references: [id])
  updatedBy     User?             @relation("UpdatedEvaluations", fields: [updatedById], references: [id])
  hiddenBy      User?             @relation("HiddenEvaluations", fields: [hiddenById], references: [id])

  @@index([organizationId])
  @@index([type])
  @@index([studentId])
  @@index([teacherId])
  @@index([courseId])
  @@index([sectionId])
  @@index([academicCycleId])
  @@index([windowId])
  @@index([isHidden])
}

model SectionSchedule {
  id              String         @id @default(uuid())
  sectionId       String
  academicCycleId String?

  day       Int      // 0 = Sunday, 1 = Monday ... 6 = Saturday
  date      DateTime?
  type      ScheduleType @default(OFFICIAL)
  startTime String   // "09:00"
  endTime   String   // "10:00"

  room      String?  // optional override
  roomId    String?
  teacherId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  section       Section        @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  roomRef       Room?          @relation("ScheduleRoom", fields: [roomId], references: [id], onDelete: SetNull)
  teacher       Teacher        @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  academicCycle AcademicCycle? @relation(fields: [academicCycleId], references: [id])

  @@index([sectionId])
  @@index([day])
  @@index([date])
  @@index([type])
  @@index([academicCycleId])
  @@index([roomId])
  @@index([teacherId])

  attendanceSessions AttendanceSession[]
}

model AttendanceSession {
  id              String         @id @default(uuid())
  sectionId       String
  scheduleId      String
  academicCycleId String?
  date            DateTime
  startTime       String?
  endTime         String?

  createdAt DateTime @default(now())

  section       Section          @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  schedule      SectionSchedule  @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  academicCycle AcademicCycle?   @relation(fields: [academicCycleId], references: [id])
  records       AttendanceRecord[]

  @@unique([scheduleId, date])
  @@index([sectionId])
  @@index([scheduleId])
  @@index([date])
  @@index([academicCycleId])
}

model AttendanceRecord {
  id         String   @id @default(uuid())
  sessionId  String
  studentId  String
  status     AttendanceStatus

  session AttendanceSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([sessionId, studentId])
  @@index([studentId])
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

enum ScheduleType {
  OFFICIAL
  AD_HOC
}

// ─── COURSE MATERIALS ────────────────────────────────────────────────────────
model CourseMaterial {
  id              String         @id @default(uuid())
  sectionId       String
  academicCycleId String?
  title           String
  description     String?
  links           String[]
  isVideoLink     Boolean        @default(false)
  createdBy       String
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  section       Section        @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  academicCycle AcademicCycle? @relation(fields: [academicCycleId], references: [id])

  @@index([sectionId])
  @@index([academicCycleId])
}

// ─── ACADEMIC LIFECYCLE SYSTEM ───────────────────────────────────────────────

enum EnrollmentSource {
  MANUAL
  COHORT
}

model AcademicCycle {
    id             String   @id @default(uuid())
    name           String
    code           String
    startDate      DateTime
    endDate        DateTime
    isActive       Boolean  @default(false)
    organizationId String
    gpaPolicyId    String?
    gpaPolicySnapshot Json?
    createdAt      DateTime @default(now())
    updatedAt      DateTime @updatedAt

    organization        Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
    gpaPolicy           GpaPolicy?            @relation(fields: [gpaPolicyId], references: [id], onDelete: SetNull)
    cohorts             Cohort[]
  sections            Section[]
  enrollments         Enrollment[]
  enrollmentHistories EnrollmentHistory[]
  cohortMembershipHistories CohortMembershipHistory[]
  assessments         Assessment[]
  grades              Grade[]
  submissions         Submission[]
  attendanceSessions  AttendanceSession[]
  courseMaterials     CourseMaterial[]
  evaluationWindows   EvaluationWindow[]
  evaluations         Evaluation[]
  sectionSchedules    SectionSchedule[]
  preferenceWindows   PreferenceWindow[]

    @@index([organizationId])
    @@index([isActive])
    @@index([gpaPolicyId])
    @@unique([organizationId, code])
  }

model Cohort {
  id              String   @id @default(uuid())
  name            String
  code            String
  organizationId  String
  academicCycleId String
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization  Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  academicCycle AcademicCycle @relation(fields: [academicCycleId], references: [id])
  students      Student[]
  sections      Section[]
  cohortMembershipHistories CohortMembershipHistory[]
  preferenceAudiences PreferenceWindowAudience[]

  @@index([organizationId])
  @@index([academicCycleId])
  @@index([isActive])
  @@unique([organizationId, code])
}

model EnrollmentHistory {
  id              String    @id @default(uuid())
  studentId       String
  sectionId       String
  academicCycleId String?

  source          EnrollmentSource @default(MANUAL)
  wasExcluded     Boolean          @default(false)

  enrolledAt      DateTime  @default(now())
  removedAt       DateTime?

  student       Student        @relation(fields: [studentId], references: [id], onDelete: Cascade)
  section       Section        @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  academicCycle AcademicCycle? @relation(fields: [academicCycleId], references: [id])

  @@index([studentId])
  @@index([sectionId])
  @@index([academicCycleId])
}

model CohortMembershipHistory {
  id              String    @id @default(uuid())
  studentId       String
  cohortId        String
  academicCycleId String?

  joinedAt        DateTime  @default(now())
  leftAt          DateTime?

  student       Student        @relation(fields: [studentId], references: [id], onDelete: Cascade)
  cohort        Cohort         @relation(fields: [cohortId], references: [id], onDelete: Cascade)
  academicCycle AcademicCycle? @relation(fields: [academicCycleId], references: [id])

  @@index([studentId])
  @@index([cohortId])
  @@index([academicCycleId])
}

// ─── FINANCIAL LEDGER SYSTEM ────────────────────────────────────────────────

enum FinanceCategory {
  TUITION
  TRANSPORT
  LIBRARY
  LIBRARY_FINE
  EXAM
  SALARY
  BONUS
  ADMISSION
  HOSTEL
  ACTIVITY
  REIMBURSEMENT
  REFUND
  LATE_FEE
  FINE
  BOOKS_SUPPLIES
  STATIONERY
  UNIFORM
  LAB
  ID_CARD
  CERTIFICATE
  TRANSCRIPT
  GRADUATION
  REGISTRATION
  APPLICATION_FEE
  PROCESSING_FEE
  DEVELOPMENT_FEE
  BUILDING_FUND
  CANTEEN
  CAFETERIA
  MEDICAL
  HEALTH
  SPORTS
  ARTS
  MUSIC
  TECHNOLOGY
  PRINTING
  PARKING
  SECURITY_DEPOSIT
  FIELD_TRIP
  EVENT
  DONATION
  GRANT
  SCHOLARSHIP
  DISCOUNT
  WAIVER
  VENDOR_PAYMENT
  ALLOWANCE
  OVERTIME
  COMMISSION
  ADVANCE
  LOAN
  TRAINING
  PROFESSIONAL_DEVELOPMENT
  TRAVEL
  MEAL
  ACCOMMODATION
  MAINTENANCE
  UTILITIES
  RENT
  EQUIPMENT
  SOFTWARE
  INTERNET
  PHONE
  OFFICE_SUPPLIES
  CLEANING
  SECURITY
  REPAIRS
  MARKETING
  LEGAL
  CONSULTING
  TAX
  INSURANCE
  BANK_CHARGE
  MISC_INCOME
  MISC_EXPENSE
  OTHER
}

enum BillingCycle {
  ONCE
  MONTHLY
  SEMESTER
  YEARLY
  ACADEMIC_CYCLE
}

enum EntryStatus {
  PENDING
  UNVERIFIED
  PARTIAL
  PAID
  OVERDUE
  CANCELLED
}

enum EntrySource {
  SYSTEM
  MANUAL
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum FinanceTargetType {
  STUDENT
  TEACHER
  SUB_ADMIN
  FINANCE_MANAGER
  OTHER_INCOME
  OTHER_EXPENSE
}

enum FinanceAssignmentSource {
  MANUAL
  SECTION
  COHORT
  COURSE
  OTHER
}

enum PaymentClaimStatus {
  PENDING
  CONFIRMED
  REJECTED
}

model FinancialStructure {
  id              String           @id @default(uuid())
  organizationId  String
  title           String           // e.g. "Standard Tuition"
  description     String?

  targetType      FinanceTargetType @default(STUDENT)
  studentId       String?
  teacherId       String?
  employeeUserId  String?

  category        FinanceCategory

  amount          Decimal          @db.Decimal(12, 2)
  currency        String           @default("USD")

  billingCycle    BillingCycle
  dueDay          Int?             // Allow null for ONCE or ACADEMIC_CYCLE

  startDate       DateTime
  endDate         DateTime?

  isActive        Boolean          @default(true)
  metadata        Json?

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  student         Student?         @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacher         Teacher?         @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  employeeUser    User?            @relation("EmployeeFinancialStructures", fields: [employeeUserId], references: [id], onDelete: Cascade)
  assignments     FinancialStructureAssignment[]
  entries         FinancialEntry[]

  @@index([organizationId])
  @@index([targetType])
  @@index([studentId])
  @@index([teacherId])
  @@index([employeeUserId])
  @@index([isActive])
}

model FinancialStructureAssignment {
  id              String                  @id @default(uuid())
  organizationId  String
  structureId     String
  targetType      FinanceTargetType
  studentId       String?
  teacherId       String?
  employeeUserId  String?
  entityName      String?
  sourceType      FinanceAssignmentSource @default(MANUAL)
  sourceId        String?
  isActive        Boolean                 @default(true)
  metadata        Json?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  organization    Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  structure       FinancialStructure      @relation(fields: [structureId], references: [id], onDelete: Cascade)
  student         Student?                @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacher         Teacher?                @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  employeeUser    User?                   @relation("EmployeeFinancialStructureAssignments", fields: [employeeUserId], references: [id], onDelete: Cascade)
  entries         FinancialEntry[]

  @@index([organizationId])
  @@index([structureId])
  @@index([targetType])
  @@index([studentId])
  @@index([teacherId])
  @@index([employeeUserId])
  @@index([sourceType])
  @@index([isActive])
  @@unique([structureId, studentId])
  @@unique([structureId, teacherId])
  @@unique([structureId, employeeUserId])
  @@unique([structureId, targetType, entityName])
}

model FinancialEntry {
  id                String             @id @default(uuid())
  organizationId    String
  structureId       String?
  assignmentId      String?

  title             String             // e.g. "September Tuition"
  
  studentId         String?
  teacherId         String?
  employeeUserId    String?

  periodStart       DateTime?
  periodEnd         DateTime?
  dueDate           DateTime

  amount            Decimal            @default(0.00) @db.Decimal(12, 2)
  paidAmount        Decimal            @default(0.00) @db.Decimal(12, 2)

  status            EntryStatus        @default(PENDING)

  markedByUser      Boolean            @default(false)
  markedAt          DateTime?
  receiptUrl        String?
  paymentMethod     String?

  confirmedByAdmin  Boolean            @default(false)
  confirmedAt       DateTime?
  confirmedById     String?

  source            EntrySource

  metadata          Json?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  organization      Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  structure         FinancialStructure? @relation(fields: [structureId], references: [id], onDelete: SetNull)
  student           Student?           @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacher           Teacher?           @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  employeeUser      User?              @relation("EmployeeFinancialEntries", fields: [employeeUserId], references: [id], onDelete: Cascade)
  confirmedBy       User?              @relation("AdminConfirmations", fields: [confirmedById], references: [id])
  assignment        FinancialStructureAssignment? @relation(fields: [assignmentId], references: [id], onDelete: SetNull)
  claims            PaymentClaim[]
  transactions      Transaction[]
  attachments       FinanceAttachment[]

  @@index([organizationId])
  @@index([assignmentId])
  @@index([studentId])
  @@index([teacherId])
  @@index([employeeUserId])
  @@index([status])
  @@index([dueDate])
  @@unique([assignmentId, periodStart, periodEnd])
}

model PaymentClaim {
  id              String             @id @default(uuid())
  organizationId  String
  entryId         String
  claimedAmount   Decimal            @db.Decimal(12, 2)
  paymentMethod   String?
  referenceNumber String?
  receiptUrl      String?
  note            String?
  status          PaymentClaimStatus @default(PENDING)
  claimedById     String
  claimedAt       DateTime           @default(now())
  reviewedById    String?
  reviewedAt      DateTime?
  confirmedAmount Decimal?           @db.Decimal(12, 2)
  rejectionReason String?
  metadata        Json?

  organization    Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  entry           FinancialEntry     @relation(fields: [entryId], references: [id], onDelete: Cascade)
  claimedBy       User               @relation("PaymentClaimants", fields: [claimedById], references: [id])
  reviewedBy      User?              @relation("PaymentClaimReviews", fields: [reviewedById], references: [id])
  attachments     FinanceAttachment[]

  @@index([organizationId])
  @@index([entryId])
  @@index([claimedById])
  @@index([reviewedById])
  @@index([status])
  @@index([claimedAt])
}

model FinanceAttachment {
  id              String   @id @default(uuid())
  organizationId  String
  entryId         String
  claimId         String?
  transactionId   String?
  fileId          String?
  url             String
  filename        String
  mimeType        String?
  size            Int?
  uploadedById    String
  uploadedAt      DateTime @default(now())

  organization    Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  entry           FinancialEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  claim           PaymentClaim?  @relation(fields: [claimId], references: [id], onDelete: Cascade)
  transaction     Transaction?   @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  uploadedBy      User           @relation("FinanceAttachmentUploaders", fields: [uploadedById], references: [id])

  @@index([organizationId])
  @@index([entryId])
  @@index([claimId])
  @@index([transactionId])
  @@index([uploadedById])
}

model Transaction {
  id              String           @id @default(uuid())
  organizationId  String

  type            TransactionType
  category        FinanceCategory

  amount          Decimal          @db.Decimal(12, 2)
  currency        String           @default("USD")
  description     String?
  metadata        Json?

  relatedEntryId  String?
  paymentMethod   String?
  referenceNumber String?

  createdById     String
  createdAt       DateTime         @default(now())

  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  relatedEntry    FinancialEntry?  @relation(fields: [relatedEntryId], references: [id], onDelete: SetNull)
  createdBy       User             @relation("UserTransactions", fields: [createdById], references: [id])
  attachments     FinanceAttachment[]

  @@index([organizationId])
  @@index([relatedEntryId])
  @@index([createdById])
}

model WebPushSubscription {
  id        String   @id @default(uuid())
  userId    String
  deviceId  String?
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, deviceId])
}
