generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
  importFileExtension = ""
}

datasource db {
  provider = "postgresql"
}

model Organization {
  id              String         @id @default(uuid())
  name            String
  location        String
  type            String
  currency        String         @default("USD")
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  contactEmail    String
  contactEmailVerifiedAt DateTime?
  contactEmailVerificationCodeHash String?
  contactEmailVerificationExpiresAt DateTime?
  contactEmailVerificationAttempts Int @default(0)
  lastVerificationSentAt DateTime?
  phone           String?
  status          OrgStatus      @default(PENDING)
  statusHistory   Json? // Stores array of { status, message, adminName, adminRole, createdAt }
  avatarUpdatedAt DateTime?
  logoUrl         String?
  accentColor     Json?
  courses         Course[]
  sections        Section[]
  students        Student[]
  teachers        Teacher[]
  guardians       GuardianProfile[]
  users           User[]
  assessments     Assessment[]
  mails           Mail[]
  parentOrgId     String?
  parentOrg       Organization?  @relation("ParentChildOrg", fields: [parentOrgId], references: [id])
  subOrgs         Organization[] @relation("ParentChildOrg")
  chats           Chat[]
  announcements   Announcement[]
  preferenceWindows PreferenceWindow[]
  holidays        Holiday[]
  evaluationWindows EvaluationWindow[]
  evaluations       Evaluation[]
  academicCycles  AcademicCycle[]
  cohorts         Cohort[]
  departments     Department[]
  buildings       Building[]
  rooms           Room[]
  teacherDepartments TeacherDepartment[]
  studentDepartments StudentDepartment[]
  managerDepartments ManagerDepartment[]
  subAdminDepartments SubAdminDepartment[]
  financialStructures FinancialStructure[]
  financialStructureAssignments FinancialStructureAssignment[]
  financialEntries    FinancialEntry[]
  paymentClaims       PaymentClaim[]
  financeAttachments  FinanceAttachment[]
  transactions        Transaction[]
  auditLogs           AuditLog[]
  guardianStudentLinks GuardianStudent[]
  gpaPolicies         GpaPolicy[]
  aiSubscriptions     AISubscription[]
  aiOrgAccessPolicy   AIOrgAccessPolicy?
  aiRoleCreditPolicies AIRoleCreditPolicy[]
  aiUsages            AIUsage[]
  aiToolCallLogs      AIToolCallLog[]
  aiConversations     AIConversation[]
  communicationBlocks UserCommunicationBlock[]

  @@index([status])
  @@index([type])
}

model User {
  id                    String             @id @default(uuid())
  email                 String             @unique
  password              String
  role                  Role               @default(SUPER_ADMIN)
  status                UserStatus         @default(ACTIVE)
  isFirstLogin          Boolean            @default(true)
  organizationId        String?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  name                  String?
  phone                 String?
  themeMode             ThemeMode          @default(SYSTEM)
  avatarUrl             String?
  avatarUpdatedAt       DateTime?
  departmentScopeType   DepartmentScopeType @default(ALL)
  studentProfile        Student?
  teacherProfile        Teacher?
  guardianProfile       GuardianProfile?
  subAdminDepartments   SubAdminDepartment[]
  organization          Organization?      @relation(fields: [organizationId], references: [id])
  sessions             Session[]
  createdMails         Mail[]         @relation("CreatedMails")
  assignedMails        Mail[]         @relation("AssignedMails")
  participatingMails   Mail[]         @relation("MailParticipants")
  sentMessages         MailMessage[]  @relation("SentMessages")
  performedActions     MailActionLog[] @relation("PerformedActions")
  viewedMails          MailUserView[]

  createdChats          Chat[]             @relation("CreatedChats")
  chatParticipations    ChatParticipant[]  @relation("ChatParticipations")
  sentChatMessages      ChatMessage[]      @relation("SentChatMessages")
  deletedChatMessages   ChatMessage[]      @relation("DeletedChatMessages")
  communicationBlocks   UserCommunicationBlock[] @relation("CommunicationBlockOwners")
  communicationBlockedBy UserCommunicationBlock[] @relation("CommunicationBlockTargets")
  encryptionIdentity     UserEncryptionIdentity?
  trustedEncryptionDevices TrustedEncryptionDevice[] @relation("TrustedEncryptionDevices")
  revokedEncryptionDevices TrustedEncryptionDevice[] @relation("RevokedEncryptionDevices")
  e2eeDeviceApprovalRequests E2EEDeviceApprovalRequest[] @relation("E2EEDeviceApprovalRequestUsers")
  e2eeKeyEnvelopes       E2EEKeyEnvelope[]  @relation("E2EEKeyEnvelopeRecipients")
  chatHistoryKeys         ChatHistoryKey[]   @relation("ChatHistoryKeyUsers")
  e2eeHistoryKeyEnvelopes E2EEHistoryKeyDeviceEnvelope[] @relation("E2EEHistoryKeyEnvelopeRecipients")
  e2eeContentHistoryKeyEnvelopes E2EEContentHistoryKeyEnvelope[] @relation("E2EEContentHistoryKeyEnvelopeRecipients")
  userNotifications     Notification[]     @relation("UserNotifications")
  createdAnnouncements  Announcement[]     @relation("CreatedAnnouncements")
  createdPreferenceWindows PreferenceWindow[] @relation("CreatedPreferenceWindows")
  updatedPreferenceWindows PreferenceWindow[] @relation("UpdatedPreferenceWindows")
  preferenceSubmissions PreferenceSubmission[] @relation("PreferenceSubmissionUsers")
  createdHolidays        Holiday[]          @relation("CreatedHolidays")
  updatedHolidays        Holiday[]          @relation("UpdatedHolidays")
  createdEvaluationWindows EvaluationWindow[] @relation("CreatedEvaluationWindows")
  updatedEvaluationWindows EvaluationWindow[] @relation("UpdatedEvaluationWindows")
  createdEvaluations      Evaluation[]      @relation("CreatedEvaluations")
  updatedEvaluations      Evaluation[]      @relation("UpdatedEvaluations")
  hiddenEvaluations       Evaluation[]      @relation("HiddenEvaluations")
  confirmedFinancialEntries FinancialEntry[] @relation("AdminConfirmations")
  claimedPayments           PaymentClaim[]    @relation("PaymentClaimants")
  reviewedPaymentClaims     PaymentClaim[]    @relation("PaymentClaimReviews")
  uploadedFinanceAttachments FinanceAttachment[] @relation("FinanceAttachmentUploaders")
  createdTransactions       Transaction[]    @relation("UserTransactions")
  employeeFinancialStructures FinancialStructure[] @relation("EmployeeFinancialStructures")
  employeeFinancialStructureAssignments FinancialStructureAssignment[] @relation("EmployeeFinancialStructureAssignments")
  employeeFinancialEntries    FinancialEntry[] @relation("EmployeeFinancialEntries")
  pushSubscriptions         WebPushSubscription[]
  passwordResetTokens       PasswordResetToken[]
  linkedAccounts            LinkedAccount[]
  aiSubscriptions           AISubscription[]
  aiUsages                  AIUsage[]
  aiToolCallLogs            AIToolCallLog[]
  aiConversations           AIConversation[]

  @@index([organizationId])
  @@index([role])
}

model LinkedAccount {
  id                String                @id @default(uuid())
  userId            String
  provider          LinkedAccountProvider
  providerAccountId String
  email             String?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@unique([userId, provider])
  @@index([userId])
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  ip        String?
  userAgent String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([usedAt])
}

model AuditLog {
  id             String   @id @default(uuid())
  action         String
  actorUserId    String?
  targetUserId   String?
  organizationId String?
  module         String?
  resourceType   String?
  resourceId     String?
  financeStructureId String?
  financeEntryId String?
  paymentClaimId String?
  transactionId  String?
  ip             String?
  userAgent      String?
  sessionId      String?
  details        Json?
  createdAt      DateTime @default(now())

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([action])
  @@index([actorUserId])
  @@index([targetUserId])
  @@index([organizationId])
  @@index([module])
  @@index([resourceType])
  @@index([resourceId])
  @@index([financeStructureId])
  @@index([financeEntryId])
  @@index([paymentClaimId])
  @@index([transactionId])
  @@index([createdAt])
}

model Session {
  id          String   @id @default(uuid())
  userId      String
  deviceId    String
  deviceName  String?  // e.g., "Chrome on Windows", "Safari on iPhone"
  deviceType  String?  // e.g., "desktop", "mobile", "tablet"
  browser     String?  // e.g., "Chrome", "Safari"
  os          String?  // e.g., "Windows", "iOS"
  location    String?  // e.g., "New York, USA"
  ip          String?  // IP address
  token       String   // JWT token for this session
  isActive    Boolean  @default(true)
  lastSeenAt  DateTime @default(now())
  createdAt   DateTime @default(now())
  expiresAt   DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([deviceId])
  @@index([isActive])
}

model UserEncryptionIdentity {
  id                String   @id @default(uuid())
  userId            String   @unique
  keyVersion        Int      @default(1)
  identityPublicKey String
  publicKeyFingerprint String?
  signingPublicKey  String?
  signingPublicKeyFingerprint String?
  algorithm         String   @default("libsodium:x25519+ed25519")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  rotatedAt         DateTime?
  disabledAt        DateTime?

  user    User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  devices TrustedEncryptionDevice[]

  @@index([userId, keyVersion])
}

model TrustedEncryptionDevice {
  id                     String    @id @default(uuid())
  userId                 String
  identityId             String?
  clientDeviceId         String
  displayName            String?
  deviceType             String?
  browser                String?
  os                     String?
  keyVersion             Int       @default(1)
  keyAgreementPublicKey  String
  keyAgreementPublicKeyFingerprint String?
  signingPublicKey       String?
  signingPublicKeyFingerprint String?
  algorithm              String    @default("libsodium:x25519+ed25519")
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  lastSeenAt             DateTime?
  trustStatus            E2EEDeviceTrustStatus @default(TRUSTED)
  approvalRequestedAt    DateTime?
  trustedAt              DateTime?
  approvedByDeviceId     String?
  revokedAt              DateTime?
  revokedById            String?

  user             User                    @relation("TrustedEncryptionDevices", fields: [userId], references: [id], onDelete: Cascade)
  identity         UserEncryptionIdentity? @relation(fields: [identityId], references: [id], onDelete: SetNull)
  revokedBy        User?                   @relation("RevokedEncryptionDevices", fields: [revokedById], references: [id], onDelete: SetNull)
  approvedByDevice TrustedEncryptionDevice? @relation("DeviceApprovalSource", fields: [approvedByDeviceId], references: [id], onDelete: SetNull)
  approvedDevices  TrustedEncryptionDevice[] @relation("DeviceApprovalSource")
  pendingApprovalRequests E2EEDeviceApprovalRequest[] @relation("PendingEncryptionDeviceApprovalRequests")
  approvalRequestsApproved E2EEDeviceApprovalRequest[] @relation("ApproverEncryptionDeviceApprovalRequests")
  keyEnvelopes     E2EEKeyEnvelope[]       @relation("E2EEKeyEnvelopeTargetDevices")
  senderEnvelopes  E2EEKeyEnvelope[]       @relation("E2EEKeyEnvelopeSenderDevices")
  historyKeyEnvelopes E2EEHistoryKeyDeviceEnvelope[] @relation("E2EEHistoryKeyEnvelopeTargetDevices")
  historyKeySenderEnvelopes E2EEHistoryKeyDeviceEnvelope[] @relation("E2EEHistoryKeyEnvelopeSenderDevices")

  @@unique([userId, clientDeviceId])
  @@index([identityId])
  @@index([userId, trustStatus, revokedAt])
  @@index([clientDeviceId])
  @@index([approvedByDeviceId])
  @@index([revokedById])
}

model E2EEDeviceApprovalRequest {
  id               String             @id @default(uuid())
  userId           String
  pendingDeviceId  String
  approverDeviceId String?
  status           E2EEApprovalStatus @default(PENDING)
  requestedAt      DateTime           @default(now())
  respondedAt      DateTime?
  expiresAt        DateTime?

  user           User                     @relation("E2EEDeviceApprovalRequestUsers", fields: [userId], references: [id], onDelete: Cascade)
  pendingDevice  TrustedEncryptionDevice  @relation("PendingEncryptionDeviceApprovalRequests", fields: [pendingDeviceId], references: [id], onDelete: Cascade)
  approverDevice TrustedEncryptionDevice? @relation("ApproverEncryptionDeviceApprovalRequests", fields: [approverDeviceId], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@index([pendingDeviceId, status])
  @@index([approverDeviceId])
  @@index([requestedAt])
}

model Teacher {
  id               String        @id @default(uuid())
  userId           String        @unique
  organizationId   String
  subject          String        @default("Unassigned")
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  designation      String        @default("Unassigned")
  education        String        @default("Unassigned")
  address          String?
  bloodGroup       String?
  department       String?
  departmentScopeType DepartmentScopeType @default(ALL)
  emergencyContact String?
  joiningDate      DateTime      @default(now())
  status           TeacherStatus @default(ACTIVE)
  organization     Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  sections         Section[]     @relation("SectionToTeacher")
  schedules        SectionSchedule[]
  teacherDepartments TeacherDepartment[]
  managerDepartments ManagerDepartment[]
  financialStructures FinancialStructure[]
  financialStructureAssignments FinancialStructureAssignment[]
  financialEntries    FinancialEntry[]
  evaluations          Evaluation[]

  @@index([organizationId])
}

model GuardianProfile {
  id             String       @id @default(uuid())
  userId         String       @unique
  organizationId String
  phone          String?
  address        String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  studentLinks   GuardianStudent[]

  @@index([organizationId])
}

model GuardianStudent {
  id                String          @id @default(uuid())
  guardianId        String
  studentId         String          @unique
  organizationId    String
  relationshipLabel String
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  guardian          GuardianProfile @relation(fields: [guardianId], references: [id], onDelete: Cascade)
  student           Student         @relation(fields: [studentId], references: [id], onDelete: Cascade)
  organization      Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([guardianId, studentId])
  @@index([guardianId])
  @@index([organizationId])
}

model Course {
  id             String       @id @default(uuid())
  name           String
  code           String
  description    String?
  creditHours    Float        @default(3)
  organizationId String
  departmentId   String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  department     Department?  @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  updatedBy      String?
  sections       Section[]
  assessments    Assessment[]
  evaluationWindows EvaluationWindow[]
  evaluations       Evaluation[]
  preferenceOptions PreferenceWindowOption[] @relation("PreferenceOptionCourse")
  preferenceAudiences PreferenceWindowAudience[] @relation("PreferenceAudienceCourse")
  @@unique([organizationId, code])

  @@index([organizationId])
  @@index([departmentId])
}

model Department {
  id             String   @id @default(uuid())
  organizationId String

  name        String
  code        String
  description String?
  color       String?
  isActive    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization        Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  buildingDepartments BuildingDepartment[]
  courses             Course[]
  teacherDepartments  TeacherDepartment[]
  studentPrimaryLinks Student[]            @relation("StudentPrimaryDepartment")
  studentDepartments  StudentDepartment[]
  managerDepartments  ManagerDepartment[]
  subAdminDepartments SubAdminDepartment[]
  holidayDepartments  HolidayDepartment[]

  @@unique([organizationId, name])
  @@unique([organizationId, code])
  @@index([organizationId])
  @@index([isActive])
}

model Building {
  id             String   @id @default(uuid())
  organizationId String

  name           String
  code           String
  address        String?
  description    String?
  landmark       String?
  directionsNote String?
  sortOrder      Int      @default(0)
  mapX           Float?
  mapY           Float?
  mapWidth       Float?
  mapHeight      Float?
  imageUrl       String?
  imageUpdatedAt DateTime?
  isActive       Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization        Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  rooms               Room[]
  buildingDepartments BuildingDepartment[]

  @@unique([organizationId, name])
  @@unique([organizationId, code])
  @@index([organizationId])
  @@index([isActive])
}

model Room {
  id             String @id @default(uuid())
  organizationId String
  buildingId     String

  name           String
  code           String
  floor          String   @default("Unspecified")
  type           RoomType?
  capacity       Int?
  description    String?
  landmark       String?
  directionsNote String?
  sortOrder      Int      @default(0)
  mapX           Float?
  mapY           Float?
  mapWidth       Float?
  mapHeight      Float?
  imageUrl       String?
  imageUpdatedAt DateTime?
  isActive       Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  building     Building     @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  defaultSections Section[] @relation("SectionDefaultRoom")
  schedules       SectionSchedule[] @relation("ScheduleRoom")

  @@unique([organizationId, buildingId, name])
  @@unique([organizationId, code])
  @@index([organizationId])
  @@index([buildingId])
  @@index([isActive])
  @@index([type])
}

model BuildingDepartment {
  id             String @id @default(uuid())
  organizationId String
  buildingId     String
  departmentId   String

  building   Building   @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  department Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@unique([buildingId, departmentId])
  @@index([organizationId])
  @@index([buildingId])
  @@index([departmentId])
}

model TeacherDepartment {
  id             String @id @default(uuid())
  organizationId String
  teacherId      String
  departmentId   String

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  teacher      Teacher      @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  department   Department   @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@unique([teacherId, departmentId])
  @@index([organizationId])
  @@index([departmentId])
}

model StudentDepartment {
  id             String @id @default(uuid())
  organizationId String
  studentId      String
  departmentId   String

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  student      Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  department   Department   @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@unique([studentId, departmentId])
  @@index([organizationId])
  @@index([departmentId])
}

model ManagerDepartment {
  id             String @id @default(uuid())
  organizationId String
  teacherId      String
  departmentId   String

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  teacher      Teacher      @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  department   Department   @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@unique([teacherId, departmentId])
  @@index([organizationId])
  @@index([departmentId])
}

model SubAdminDepartment {
  id             String @id @default(uuid())
  organizationId String
  userId         String
  departmentId   String

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  department   Department   @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@unique([userId, departmentId])
  @@index([organizationId])
  @@index([departmentId])
}

enum GpaCalculationMethod {
  SIMPLE_AVERAGE
  WEIGHTED_BY_CREDIT_HOURS
}

enum GpaRounding {
  NONE
  ONE_DECIMAL
  TWO_DECIMALS
}

model GpaPolicy {
    id             String               @id @default(uuid())
    organizationId String
    name           String
    scale          Float                @default(4.0)
    method         GpaCalculationMethod @default(WEIGHTED_BY_CREDIT_HOURS)
    rounding       GpaRounding          @default(TWO_DECIMALS)
    gradeRules     Json
    isDefault      Boolean              @default(false)
    isArchived     Boolean              @default(false)
    createdAt      DateTime             @default(now())
    updatedAt      DateTime             @updatedAt

    organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
    academicCycles AcademicCycle[]

    @@index([organizationId])
    @@index([isDefault])
    @@index([isArchived])
  }

model Section {
  id               String       @id @default(uuid())
  organizationId   String
  name             String
  code             String
  color            String       @default("#3B82F6")
  room             String?
  defaultRoomId    String?
  courseId         String
  academicCycleId  String
  cohortId         String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  enrollments      Enrollment[]
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  course           Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  defaultRoom      Room?        @relation("SectionDefaultRoom", fields: [defaultRoomId], references: [id], onDelete: SetNull)
  academicCycle    AcademicCycle @relation(fields: [academicCycleId], references: [id])
  cohort           Cohort?      @relation(fields: [cohortId], references: [id])
  teachers         Teacher[]    @relation("SectionToTeacher")
  schedules          SectionSchedule[]
  attendanceSessions AttendanceSession[]
  assessments        Assessment[]
  evaluationWindows  EvaluationWindow[]
  evaluations        Evaluation[]
  courseMaterials    CourseMaterial[]
  enrollmentHistories EnrollmentHistory[]
  preferenceOptions PreferenceWindowOption[] @relation("PreferenceOptionSection")
  preferenceAudiences PreferenceWindowAudience[] @relation("PreferenceAudienceSection")
  @@unique([organizationId, code])
  @@index([organizationId])

  @@index([courseId])
  @@index([defaultRoomId])
  @@index([academicCycleId])
  @@index([cohortId])
}

model Enrollment {
  id                    String           @id @default(uuid())
  studentId             String
  sectionId             String
  academicCycleId       String?
  source                EnrollmentSource @default(MANUAL)
  isExcludedFromCohort  Boolean          @default(false)
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  section               Section          @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  student               Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  academicCycle         AcademicCycle?   @relation(fields: [academicCycleId], references: [id])

  @@unique([studentId, sectionId])
  @@index([sectionId])
  @@index([studentId])
  @@index([academicCycleId])
}

model Student {
  id                 String        @id @default(uuid())
  userId             String        @unique
  organizationId     String
  cohortId           String?
  registrationNumber String        @default("TEMP_ID")
  rollNumber         String        @default("TEMP_ROLL")
  fatherName         String?
  age                Int?
  address            String?
  major              String        @default("Unassigned")
  updatedBy          String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  admissionDate      DateTime      @default(now())
  bloodGroup         String?
  department         String?
  primaryDepartmentId String?
  emergencyContact   String?
  gender             String        @default("Unassigned")
  graduationDate     DateTime?
  status             StudentStatus @default(ACTIVE)
  enrollments        Enrollment[]
  organization       Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  primaryDepartment  Department?   @relation("StudentPrimaryDepartment", fields: [primaryDepartmentId], references: [id], onDelete: SetNull)
  user               User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  studentDepartments StudentDepartment[]
  cohort             Cohort?       @relation(fields: [cohortId], references: [id])
  guardianLinks      GuardianStudent[]
  grades             Grade[]
  evaluations         Evaluation[]
  submissions        Submission[]
  preferenceSubmissions PreferenceSubmission[]
  attendanceRecords  AttendanceRecord[]
  enrollmentHistories     EnrollmentHistory[]
  cohortMembershipHistories CohortMembershipHistory[]
  financialStructures FinancialStructure[]
  financialStructureAssignments FinancialStructureAssignment[]
  financialEntries    FinancialEntry[]

  @@index([organizationId])
  @@index([cohortId])
  @@index([primaryDepartmentId])
}

model Assessment {
  id               String         @id @default(uuid())
  sectionId        String
  courseId         String
  title            String
  type             AssessmentType
  totalMarks       Float
  weightage        Float // percentage 0-100
  dueDate          DateTime?
  allowSubmissions Boolean        @default(true)
  externalLink     String?
  isVideoLink      Boolean        @default(false)
  academicCycleId  String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  section          Section        @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  course           Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  organization     Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  academicCycle    AcademicCycle? @relation(fields: [academicCycleId], references: [id])
  organizationId   String
  grades           Grade[]
  submissions      Submission[]

  @@index([sectionId])
  @@index([courseId])
  @@index([dueDate])
  @@index([academicCycleId])
}

model Grade {
  id              String         @id @default(uuid())
  assessmentId    String
  studentId       String
  marksObtained   Float
  feedback        String?
  status          GradeStatus    @default(DRAFT)
  academicCycleId String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  updatedBy       String? // userId
  finalizedById   String?
  finalizedAt     DateTime?
  lastCorrectedById String?
  lastCorrectedAt DateTime?
  correctionReason String?
  assessment      Assessment     @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  student         Student        @relation(fields: [studentId], references: [id], onDelete: Cascade)
  academicCycle   AcademicCycle? @relation(fields: [academicCycleId], references: [id])

  @@unique([assessmentId, studentId])
  @@index([studentId])
  @@index([academicCycleId])
}

model Submission {
  id              String         @id @default(uuid())
  assessmentId    String
  studentId       String
  fileUrl         String?
  message         String?
  academicCycleId String?
  submittedAt     DateTime       @default(now())
  assessment      Assessment     @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  student         Student        @relation(fields: [studentId], references: [id], onDelete: Cascade)
  academicCycle   AcademicCycle? @relation(fields: [academicCycleId], references: [id])

  @@index([academicCycleId])
}

// ─── Mail System ────────────────────────────────────────────────────────────────

model Mail {
  id       String        @id @default(uuid())
  subject  String
  category String // flexible string, not rigid enum
  priority String        @default("NORMAL") // LOW, NORMAL, HIGH, URGENT
  status   MailStatus @default(OPEN)

  // Creator context
  creatorId   String
  creatorRole String
  creator     User   @relation("CreatedMails", fields: [creatorId], references: [id])

  // Organization context (nullable for platform-level mails)
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Targeting (who should handle it)
  targetRole String? // e.g. "SUPER_ADMIN", "PLATFORM_ADMIN"
  assigneeId String?
  assignee   User?   @relation("AssignedMails", fields: [assigneeId], references: [id])
  assignees  User[]  @relation("MailParticipants")

  // Extensibility
  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages   MailMessage[]
  actionLogs MailActionLog[]
  userViews  MailUserView[]
  subjectEncryptedContent EncryptedContent? @relation("MailSubjectEncryptedContent")

  @@index([creatorId])
  @@index([organizationId])
  @@index([status])
  @@index([assigneeId])
}

model MailUserView {
  userId       String
  mailId       String
  lastViewedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  mail Mail @relation(fields: [mailId], references: [id], onDelete: Cascade)

  @@id([userId, mailId])
}

model MailMessage {
  id     String @id @default(uuid())
  mailId String
  senderId String
  content  String // markdown supported

  mail   Mail @relation(fields: [mailId], references: [id], onDelete: Cascade)
  sender User @relation("SentMessages", fields: [senderId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  // Files linked via existing File model (entityType: "MAIL_MESSAGE", entityId: message.id)
  encryptedContent EncryptedContent? @relation("MailMessageEncryptedContent")

  @@index([mailId])
  @@index([senderId])
}

model MailActionLog {
  id          String  @id @default(uuid())
  mailId      String
  performedBy String
  action      String // "CREATED", "STATUS_CHANGED", "ASSIGNED", "MESSAGE_SENT", etc.
  details     Json? // e.g. { from: "OPEN", to: "IN_PROGRESS" }
  note        String?

  mail      Mail @relation(fields: [mailId], references: [id], onDelete: Cascade)
  performer User @relation("PerformedActions", fields: [performedBy], references: [id])

  createdAt DateTime @default(now())

  @@index([mailId])
}

// ────────────────────────────────────────────────────────────────────────────────

model File {
  id           String   @id @default(uuid())
  orgId        String
  entityType   String
  entityId     String
  path         String
  publicId     String?
  filename     String
  mimeType     String
  size         Int
  uploadedBy   String
  resourceType String   @default("raw")
  deliveryType String   @default("authenticated")
  fileKind     String   @default("document")
  extension    String?
  sha256       String?
  scanStatus   String   @default("PASSED")
  createdAt    DateTime @default(now())
  encryptedContent EncryptedContent? @relation("FileEncryptedContent")

  @@index([entityType, entityId])
  @@index([sha256])
}

